# ─────────────────────────────────────────
# .env.example — Template environment variables
# Copy to .env and fill in the values
# NEVER commit .env to git!
# ─────────────────────────────────────────

# ── App ──────────────────────────────────
APP_ENV=production
APP_NAME=restful-template
APP_VERSION=1.0.0

# ── HTTP ─────────────────────────────────
HTTP_PORT=8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s

# ── Database (PostgreSQL) ───────────────────────────
# DSN is auto-built from the variables below in docker-compose.yml
POSTGRES_USER=todo
POSTGRES_PASSWORD=CHANGE_TO_STRONG_PASSWORD
POSTGRES_DB=todo
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=5m
# Disable in multi-replica deployments; run migrations via an init-container instead
DATABASE_RUN_MIGRATIONS=false
DATABASE_DSN=postgres://todo:CHANGE_TO_STRONG_PASSWORD@db:5432/todo?sslmode=disable

# ── Redis ─────────────────────────────────
REDIS_PASSWORD=CHANGE_TO_STRONG_PASSWORD
REDIS_DSN=redis://:CHANGE_TO_STRONG_PASSWORD@redis:6379/0

# ── JWT ───────────────────────────────────────
# Use a cryptographically random 64-char string (e.g. `openssl rand -hex 32`)
JWT_SECRET=CHANGE_TO_RANDOM_64_CHAR_STRING
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
JWT_ISSUER=restful-template
JWT_AUDIENCE=restful-template

# ── Logging ───────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json

# ── Telemetry (OpenTelemetry) ───────────────────────
# Alloy is the local OTLP collector — already wired in docker-compose.yml
# Set to empty string to disable tracing
TELEMETRY_OTLP_ENDPOINT=alloy:4317

# ── CORS ───────────────────────────────────────
# Comma-separated list of allowed origins. NEVER use * in production.
# Example: https://app.example.com,https://admin.example.com
CORS_ALLOWED_ORIGINS=https://your-app.example.com

# ── Grafana Observability Stack ───────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_TO_STRONG_PASSWORD
GRAFANA_ROOT_URL=http://localhost:3000

# ── Docker Hub ───────────────────────────
# Docker Hub image name (without tag)
DOCKER_IMAGE=sammidev/restful-template
IMAGE_TAG=latest
