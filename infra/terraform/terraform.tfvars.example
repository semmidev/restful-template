# Copy this file to terraform.tfvars and fill in the values.
# NEVER commit terraform.tfvars to git!

do_token     = "dop_v1_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
project_name = "restful-template"
environment  = "production"
region       = "sgp1"           # Singapore — closest for Indonesia
droplet_size = "s-1vcpu-2gb"   # ~$12/mo — suitable for this Go app + PostgreSQL + Redis
ssh_key_name = "my-macbook"    # Must already be uploaded to the DO dashboard
domain       = ""               # Leave empty if no domain yet, e.g.: "api.example.com"

# Restrict SSH to your IP only (recommended for production)
# ssh_allowed_ips = ["203.0.113.1/32"]

# Set to true if this is a new project that needs to be created in DigitalOcean.
# Set to false to attach resources to an existing project (prevents 'Already Exists' error).
create_project = false
