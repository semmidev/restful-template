# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME='Todo App'
APP_DESCRIPTION='Production-ready Todo REST API built with Huma v2 + Chi.'
APP_VERSION=1.0.0

# ── HTTP Server ───────────────────────────────────────────────────────────────
HTTP_PORT=8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_DSN=postgres://todo:todo@localhost:5432/todo?sslmode=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=5m

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_DSN=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 bytes in production
JWT_SECRET=change-me-in-production-min-32-bytes!
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# ── Logging ───────────────────────────────────────────────────────────────────
# level: debug | info | warn | error
# format: json | text
LOG_LEVEL=info
LOG_FORMAT=json

# ── Telemetry ─────────────────────────────────────────────────────────────────
TELEMETRY_OTLP_ENDPOINT=localhost:4317
