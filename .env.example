# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_NAME='Todo App'
APP_DESCRIPTION='Production-ready Todo REST API built with Huma v2 + Chi.'
APP_VERSION=1.0.0

# ── HTTP Server ───────────────────────────────────────────────────────────────
HTTP_PORT=8080
HTTP_READ_TIMEOUT=15s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_DSN=postgres://todo:todo@postgres:5432/todo?sslmode=disable
DATABASE_MAX_OPEN_CONNS=25
DATABASE_MAX_IDLE_CONNS=5
DATABASE_CONN_MAX_LIFETIME=5m
# Set to false in multi-replica deployments to avoid advisory-lock contention
DATABASE_RUN_MIGRATIONS=true

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_DSN=redis://redis:6379/0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 bytes in production
JWT_SECRET=change-me-in-production-min-32-bytes!
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
JWT_ISSUER=restful-template
JWT_AUDIENCE=restful-template

# ── Logging ───────────────────────────────────────────────────────────────────
# level: debug | info | warn | error
# format: json | text
LOG_LEVEL=info
LOG_FORMAT=json

# ── Telemetry ─────────────────────────────────────────────────────────────────
TELEMETRY_OTLP_ENDPOINT=alloy:4317

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins. Use * for development only.
# In production set to: https://your-app.example.com
CORS_ALLOWED_ORIGINS=*
