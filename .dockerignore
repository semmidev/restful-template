# Files and directories ignored when sending build context to Docker daemon

# Git
.git/
.github/
.gitignore

# Environment variables (Critical for security)
.env
.env.*
*.local

# Go build & dependencies
vendor/
bin/
tmp/
coverage.out
*.out
*.test

# Documentation & Scripts
*.md
LICENSE
Makefile

# Infra, Docker & Ansible
infra/
config/
.dockerignore
Dockerfile
docker-compose.yml
.ansible/

# OS & IDE files
.DS_Store
.idea/
.vscode/
*.swp
*.log
*.tmp
*.bak

AGENTS.md
assets/
references/
server
scheduler
worker

# Testing & Linting
tests/
.golangci.yml

# Other Dockerfiles
Dockerfile.*

# Frontend build & dependencies
frontend/node_modules/
frontend/dist/
internal/web/dist/

